<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CalculatorSuite" parallel="methods" thread-count="2">

    <test name="testCalculator">
        <groups>
            <run>
                <include name="math_operations" />
            </run>
        </groups>

        <classes>
            <class name="com.epam.tests.SumTest" />
            <class name="com.epam.tests.SubtractorTest" />
            <class name="com.epam.tests.DividerTest" />
            <class name="com.epam.tests.MultiplierTest" />
        </classes>
    </test>
</suite>